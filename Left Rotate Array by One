package Arrays;

public class rev1st_element {


	public static void main(String[] args) {
	
		int arr[] = {23,45,77,89};
		
		
		rotateleft(arr);
		
		for(int num : arr) {
			
			System.out.println(" " +num);
		}
		

	}
	
	static void rotateleft(int[] arr) {
		
		int first=arr[0];
		
		for(int i =0;i<arr.length-1;i++) {
			arr[i]=arr[i+1];
			
			
		}
		
		arr[arr.length-1]=first;
		
		
	}

}
